{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",          /* Change from ESNext to NodeNext */
    "moduleResolution": "NodeNext", /* Change from Node to NodeNext */
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}